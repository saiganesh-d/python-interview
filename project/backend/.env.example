# Copy to .env for local dev, and set real values in production (via Secrets Manager / SSM).
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production database (RDS). Leave unset locally to use SQLite.
# DATABASE_URL=postgres://USER:PASSWORD@your-db.xxxx.rds.amazonaws.com:5432/quicknotes
